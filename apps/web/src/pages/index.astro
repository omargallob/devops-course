---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home">
  <div class="py-16 text-center">
    <h1 class="text-5xl font-bold text-white mb-4">Go for DevOps</h1>
    <p class="text-xl text-gray-400 mb-8 max-w-2xl mx-auto">
      An interactive, open-source course to master Go for DevOps engineering.
      Build CLI tools, automate Docker, orchestrate Kubernetes, and more.
    </p>
    <a
      href="/modules"
      class="inline-block rounded-lg bg-emerald-600 px-6 py-3 font-semibold text-white hover:bg-emerald-500 transition-colors"
    >
      Start Learning
    </a>
  </div>
</BaseLayout>
