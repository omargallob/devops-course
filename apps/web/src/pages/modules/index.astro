---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { modules } from '../../utils/modules';
---

<BaseLayout title="Modules">
  <h1 class="text-3xl font-bold text-white mb-8">Course Modules</h1>
  <div class="grid gap-6 md:grid-cols-2">
    {modules.map((mod) => (
      <a
        href={mod.upcoming ? undefined : `/modules/${mod.slug}`}
        class:list={[
          'block rounded-lg border border-gray-800 p-6 transition-colors',
          mod.upcoming ? 'opacity-50 cursor-not-allowed' : 'hover:border-emerald-600',
        ]}
      >
        <div class="flex items-center justify-between mb-2">
          <h2 class="text-xl font-semibold text-white">{mod.title}</h2>
          {mod.upcoming && (
            <span class="text-xs rounded bg-gray-800 px-2 py-1 text-gray-400">Coming Soon</span>
          )}
        </div>
        <p class="text-gray-400 mb-4">{mod.description}</p>
        <div class="flex gap-4 text-sm text-gray-500">
          <span>{mod.lessonCount} lessons</span>
          <span class="capitalize">{mod.difficulty}</span>
        </div>
      </a>
    ))}
  </div>
</BaseLayout>
